# ~/lab/config-work/tools/Brewfile — single source of truth for installed CLI tools.
#
# Managed with `brew bundle` (Homebrew 5.x), which handles brew, cargo, go,
# uv, and npm entries from this one file.
#
#   just tools-update    install + upgrade everything listed here
#   just tools-check     verify everything here is installed
#   just tools-dump      regenerate this file from what's currently installed
#   just tools-cleanup   list (or remove) anything installed but NOT listed here
#
# OS built-ins from curr-cli.md (sed, awk, xargs, less, curl, sort/uniq/cut/
# tr/tee, lsof) are intentionally NOT tracked here — they ship with the system.
# Note: macOS has no `ss` or `strace` — the fzf helpers use `lsof` (sockets) and
# there's no dtruss-free strace equivalent; install one from brew if you need it.

# ── Modern CLI toolkit (from notes/work/learning/curr-cli.md) ──────────────
brew "ripgrep"      # rg — content search
brew "fd"           # file finder
brew "fzf"          # fuzzy finder
brew "sd"           # find-replace (rg-compatible regex, in-place edits)
brew "ast-grep"     # structural code search/refactor (sg)
brew "jq"           # JSON query
brew "bat"          # cat with highlighting
brew "eza"          # modern ls (fzf dir previews)
brew "git-delta"    # diff pager
brew "lazygit"      # git TUI (shell `lg` alias + nvim <leader>gg)
brew "zellij"       # terminal multiplexer
brew "tmux"         # terminal multiplexer (alt)
brew "zoxide"       # smarter cd
brew "yazi"         # file manager
brew "difftastic"   # structural diff (difft)
brew "just"         # task runner
brew "direnv"       # per-directory env
brew "watchexec"    # file watcher
brew "entr"         # file watcher (alt)
brew "parallel"     # GNU parallel
brew "socat"        # socket swiss-army knife
brew "httpie"       # friendly HTTP client
brew "xh"           # fast HTTP client
brew "hexyl"        # hex viewer
brew "miller"       # CSV/TSV/JSON wrangler (mlr)
brew "procs"        # modern ps
brew "htop"         # process viewer
brew "btop"         # process viewer (graphs)
brew "tlrc"         # tldr client
brew "typst"        # typesetting
brew "gh"           # github CLI

# ── Language servers / formatters (consumed by Claude Code, VSCode) ────────
brew "lua-language-server"  # lua LSP
brew "stylua"               # lua formatter

# ── Other brew tools already in use ────────────────────────────────────────
brew "bob"          # neovim version manager
brew "tree-sitter"  # parser builder for nvim-treesitter (main branch)
brew "stow"         # dotfiles symlink manager
brew "ffmpeg"       # media transcoding
brew "webp"         # webp encode/decode

# ── Fonts (casks, macOS) ───────────────────────────────────────────────────
# Nerd Font for terminal glyphs (iTerm2 profile font + nvim/zellij/yazi icons).
cask "font-jetbrains-mono-nerd-font"
